\documentclass[11pt,letterpaper]{article}

\usepackage[margin=0.85in]{geometry}
\usepackage{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{enumitem}
\usepackage{titlesec}
\usepackage{hyperref}
\usepackage{xcolor}
\usepackage{tabularx}
\usepackage{fancyhdr}
\usepackage{lastpage}

% Colors
\definecolor{navyblue}{HTML}{1a2744}
\definecolor{darkgrey}{HTML}{555555}

% Hyperlinks
\hypersetup{
  colorlinks=true,
  urlcolor=navyblue,
  linkcolor=navyblue
}

% Section formatting — small caps, navy, with rule
\titleformat{\section}
  {\large\scshape\color{navyblue}}
  {}
  {0em}
  {}
  [\titlerule]

\titlespacing*{\section}{0pt}{1.2em}{0.5em}

% No paragraph indent
\setlength{\parindent}{0pt}

% List settings
\setlist[itemize]{leftmargin=1.5em, itemsep=0pt, parsep=2pt, topsep=2pt}

% Header/footer
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[L]{\small\color{darkgrey} << cv.personal.name >>}
\fancyfoot[C]{\small\color{darkgrey} \thepage\ of \pageref{LastPage}}
\fancyfoot[R]{\small\color{darkgrey} Last updated: \today}

\begin{document}

% ---- HEADER ----
\begin{center}
  {\LARGE\scshape << cv.personal.name >>}\\[6pt]
  {\small
    << cv.personal.email | replace("@", "[at]") | replace(".", "[dot]", 1) >>
    \hfill
    \href{<< cv.personal.website >>}{<< cv.personal.website | replace("https://", "") >>}
  }
\end{center}

\vspace{0.3em}
\hrule
\vspace{0.8em}

% ---- ACADEMIC POSITIONS ----
<% if cv.academic_positions %>
\section*{Academic Positions}
<% for pos in cv.academic_positions %>
\textbf{<< pos.title >>} \hfill << pos.location >>\\
\textit{<< pos.institution >>} \hfill << pos.years >>\\[4pt]
<% endfor %>
<% endif %>

% ---- EDUCATION ----
\section*{Education}
<% for edu in cv.education %>
\textbf{<< edu.institution >>} \hfill << edu.location >>\\
\textit{<< edu.degree >>} \hfill << edu.years >>
<% for detail in edu.details %>
\begin{itemize}[leftmargin=1.5em]
  \item << detail >>
\end{itemize}
<% endfor %>
\vspace{4pt}
<% endfor %>

% ---- RESEARCH FIELDS ----
\section*{Research Fields}
<< cv.research_fields | join(", ") >>

% ---- PEER-REVIEWED ARTICLES ----
\section*{Peer-Reviewed Articles}
\begin{enumerate}[leftmargin=1.5em]
<% for pub in cv.publications.peer_reviewed %>
  \item << pub.authors | replace("Bamezai, Apurva", "\\textbf{Bamezai, Apurva}") | replace("Apurva Bamezai", "\\textbf{Apurva Bamezai}") >>.
  << pub.title >>.
  \textit{<< pub.journal >>}<% if pub.volume %>, << pub.volume >><% endif %><% if pub.year %>, << pub.year >><% endif %>.
  <% if pub.status %>(<< pub.status >>)<% endif %>
  <% if pub.url %>Available at: \href{<< pub.url >>}{<< pub.url >>}.<% endif %>
<% endfor %>
\end{enumerate}

% ---- WORKS IN PROGRESS ----
\section*{Works in Progress / Under Review}
\begin{enumerate}[leftmargin=1.5em]
<% for pub in cv.publications.works_in_progress %>
  \item << pub.authors | replace("Bamezai, Apurva", "\\textbf{Bamezai, Apurva}") | replace("Apurva Bamezai", "\\textbf{Apurva Bamezai}") >>.
  << pub.title >>.
  <% if pub.status %><< pub.status >>.<% endif %>
  <% if pub.url %>Available at: \href{<< pub.url >>}{<< pub.url >>}.<% endif %>
<% endfor %>
\end{enumerate}

% ---- AWARDS, GRANTS & FUNDING ----
\section*{Awards, Grants \& Funding}
<% for grant in cv.awards.project_grants %>
\begin{itemize}[leftmargin=0em, label={}]
  \item \textbf{<< grant.project >>:}
  <% for funder in grant.funders %>
  \begin{itemize}[leftmargin=1.5em]
    \item << funder.name >> (<< funder.amount >>) \hfill << funder.years >>
  \end{itemize}
  <% endfor %>
\end{itemize}
<% endfor %>
<% for award in cv.awards.individual %>
<< award.name >><% if award.amount %> (<< award.amount >>)<% endif %> \hfill << award.years >>\\[2pt]
<% endfor %>

% ---- PROFESSIONAL POSITIONS ----
\section*{Professional Positions}
<% for pos in cv.professional_positions %>
\textbf{<< pos.title >>} \hfill << pos.years >>\\
\textit{<< pos.institution >>}\\[4pt]
<% endfor %>

% ---- TEACHING ----
\section*{Teaching}
\textbf{<< cv.teaching.role >>}
\begin{itemize}[leftmargin=1.5em]
<% for course in cv.teaching.courses %>
  \item << course.name >> (for << course.instructor >>) \hfill << course.semester >>
<% endfor %>
<% for t in cv.teaching.training %>
  \item << t >>
<% endfor %>
\end{itemize}

% ---- CONFERENCES ----
\section*{Conferences \& Workshops}
<% for conf in cv.conferences %>
<< conf.name >><% if conf.location %>, << conf.location >><% endif %> \hfill << conf.year >>\\[2pt]
<% endfor %>

% ---- SERVICE ----
\section*{Service}
<% for s in cv.service %>
<< s.event >> (<< s.role >>) \hfill << s.year >>\\[2pt]
<% endfor %>

% ---- POLICY WRITING ----
\section*{Select Policy Writing}
\begin{enumerate}[leftmargin=1.5em]
<% for pub in cv.publications.policy_writing %>
  \item << pub.authors | replace("Bamezai, Apurva", "\\textbf{Bamezai, Apurva}") | replace("Apurva Bamezai", "\\textbf{Apurva Bamezai}") >>.
  << pub.title >>.
  \textit{<< pub.venue >>}, << pub.year >>.
  <% if pub.note %><< pub.note >>.<% endif %>
<% endfor %>
\end{enumerate}

% ---- INTERNSHIPS ----
\section*{Internships \& Volunteer Work}
<% for intern in cv.internships %>
<% if intern.role %>\textbf{<< intern.role >>}, <% endif %><< intern.organization >> \hfill << intern.period >>\\[2pt]
<% endfor %>

% ---- SKILLS ----
\section*{Skills}
\textbf{Technical:} << cv.skills.technical | join(", ") >>\\
\textbf{Languages:} <% for lang in cv.skills.languages %><< lang.language >> (<< lang.proficiency >>)<% if not loop.last %>; <% endif %><% endfor %>\\
\textbf{Courses:}
\begin{itemize}[leftmargin=1.5em]
<% for course in cv.skills.courses %>
  \item << course >>
<% endfor %>
\end{itemize}

% ---- FIELDWORK ----
\section*{Fieldwork}
\textbf{India:} << cv.fieldwork.india | join(", ") >>\\
\textbf{Outside India:} << cv.fieldwork.outside_india | join(", ") >>

\end{document}
